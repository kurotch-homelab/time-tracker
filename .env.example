# Copy to .env for local work. Never commit the populated file.
DATABASE_URL=postgresql://time_tracker:replace-me@127.0.0.1:5432/time_tracker
PUBLIC_ORIGIN=http://localhost:3000
OIDC_ISSUER_URL=https://sso.example.com/realms/time-tracker
OIDC_CLIENT_ID=time-tracker-web
OIDC_CLIENT_SECRET=replace-me
OIDC_ORGANIZATION_CLAIM=organization
OIDC_ROLE_CLAIM=roles
# Set to tauri://localhost only when running a Tauri desktop build against this API.
DESKTOP_ORIGIN=
# Set to chrome-extension://<published-extension-id> after organization deployment.
CHROME_EXTENSION_ORIGIN=
SESSION_LIFETIME_HOURS=24
