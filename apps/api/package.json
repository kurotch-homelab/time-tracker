{
  "name": "@time-tracker/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @time-tracker/core build && tsc -p tsconfig.json",
    "dev": "pnpm --filter @time-tracker/core build && tsx --env-file-if-exists=../../.env watch src/server.ts",
    "lint": "pnpm --filter @time-tracker/core build && tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @time-tracker/core build && vitest run",
    "typecheck": "pnpm --filter @time-tracker/core build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@time-tracker/core": "workspace:*",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "helmet": "^8.1.0",
    "openid-client": "^6.8.1",
    "pg": "^8.16.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.5",
    "vitest": "^3.2.4"
  }
}
