{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Time Tracker",
  "version": "0.1.0",
  "identifier": "io.github.kurotch-homelab.time-tracker",
  "build": {
    "beforeDevCommand": "pnpm --dir ../web dev -- --host 127.0.0.1",
    "beforeBuildCommand": "pnpm --dir ../web build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Time Tracker",
        "width": 1000,
        "height": 720,
        "minWidth": 480,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://time-tracker.apps.silver-vine.jp; img-src 'self' data:; style-src 'self'; script-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
