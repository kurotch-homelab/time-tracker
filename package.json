{
  "name": "time-tracker",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kurotch-homelab/time-tracker.git"
  },
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "pnpm -r build",
    "audit": "pnpm audit --prod --audit-level=high",
    "dev:api": "pnpm --filter @time-tracker/api dev",
    "dev:web": "pnpm --filter @time-tracker/web dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
